{
  "name": "better-modmaker",
  "private": true,
  "version": "1.0.6",
  "description": "Better Sound.Maker — Create DCS World sound mods easily",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "vite build && electron-builder"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^40.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.2",
    "vite": "^6.1.0"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "glob": "^11.0.0"
  },
  "dependencies": {
    "@simonwep/pickr": "^1.9.1",
    "electron-updater": "^6.8.3",
    "idb-keyval": "^6.2.2",
    "jszip": "^3.10.1",
    "lucide": "^0.574.0",
    "wavesurfer.js": "^7.12.1"
  },
  "build": {
    "appId": "com.bettersoundmaker.app",
    "productName": "Better Sound.Maker",
    "icon": "public/Bm.png",
    "publish": [
      {
        "provider": "github",
        "owner": "FreeProject089",
        "repo": "Better-ModMaker",
        "vPrefixedTagName": false
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "Bm.png",
      "public/**",
      "Update/**",
      "LICENSE"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "Better.Sound.Maker.Setup.${version}.${ext}"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
