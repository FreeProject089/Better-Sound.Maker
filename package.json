{
  "name": "better-sound-maker",
  "version": "1.9.1",
  "description": "Better Sound.Maker — Create DCS World sound mods easily",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "vite build && electron-builder"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^40.5.0",
    "electron-builder": "^26.8.1",
    "vite": "^6.1.0"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "glob": "^11.0.0"
  },
  "dependencies": {
    "i18next": "^25.8.11",
    "i18next-http-backend": "^3.0.2",
    "idb-keyval": "^6.2.2",
    "jszip": "^3.10.1",
    "lucide": "^0.574.0"
  },
  "build": {
    "appId": "com.bettersoundmaker.app",
    "productName": "Better Sound.Maker",
    "icon": "public/Bm.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "Bm.png",
      "public/**"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
